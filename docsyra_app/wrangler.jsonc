/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "docsyra",
	"compatibility_date": "2025-07-05",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"pages_build_output_dir": ".vercel/output/static",
	"observability": {
		"enabled": true
	},
	"vars": {
		"ENV_NAME": "local",
		"NEXT_PUBLIC_APP_URL": "http://localhost:3000",
		"NEXT_PUBLIC_R2_BASE_URL": "https://assets.docsyra.app",
		"NEXT_PUBLIC_COLLAB_WS_BASE_URL": "wss://docsyra-collab.hafizmmoaz.workers.dev",
		"GOOGLE_CLIENT_ID": "20679416807-1261uspg6gmve8tt9m21eqd18dcghol2.apps.googleusercontent.com",
		"GITHUB_CLIENT_ID": "Ov23liUJ1IQ3Wh21gGnu",
		"PASSKEY_RP_ID": "localhost",
		"PASSKEY_ORIGIN": "http://localhost:3000",
		"PASSKEY_RP_NAME": "Docsyra",
		"BASE_URL": "https://docsyra.app"
	},
	"env": {
		"production": {
			"name": "docsyra-production",
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "docsyra-db",
					"database_id": "1139630c-8b1e-440e-9b42-58b2ae1d4d03"
				}
			],
			"vars": {
				"ENV_NAME": "production",
				"NEXT_PUBLIC_APP_URL": "https://docsyra.app",
				"NEXT_PUBLIC_R2_BASE_URL": "https://assets.docsyra.app",
				"NEXT_PUBLIC_COLLAB_WS_BASE_URL": "wss://docsyra-collab.hafizmmoaz.workers.dev",
				"GOOGLE_CLIENT_ID": "20679416807-1261uspg6gmve8tt9m21eqd18dcghol2.apps.googleusercontent.com",
				"GITHUB_CLIENT_ID": "Ov23liUlceVJbHP788uO",
				"PASSKEY_RP_ID": "docsyra.app",
				"PASSKEY_ORIGIN": "https://docsyra.app",
				"PASSKEY_RP_NAME": "Docsyra"
			}
		},
		"preview": {
			"name": "docsyra-preview",
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "docsyra-db",
					"database_id": "1139630c-8b1e-440e-9b42-58b2ae1d4d03"
				}
			],
			"vars": {
				"ENV_NAME": "preview",
				"NEXT_PUBLIC_APP_URL": "https://preview.docsyra.app",
				"NEXT_PUBLIC_R2_BASE_URL": "https://assets.docsyra.app",
				"NEXT_PUBLIC_COLLAB_WS_BASE_URL": "wss://docsyra-collab.hafizmmoaz.workers.dev",
				"GOOGLE_CLIENT_ID": "20679416807-1261uspg6gmve8tt9m21eqd18dcghol2.apps.googleusercontent.com",
				"GITHUB_CLIENT_ID": "Ov23liUlceVJbHP788uO",
				"PASSKEY_RP_ID": "preview.docsyra.app",
				"PASSKEY_ORIGIN": "https://preview.docsyra.app",
				"PASSKEY_RP_NAME": "Docsyra"
			}
		}
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "docsyra-db",
			"database_id": "1139630c-8b1e-440e-9b42-58b2ae1d4d03"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "docsyra-assets"
		}
	]
}